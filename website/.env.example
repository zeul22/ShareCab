# Website env — all values are NEXT_PUBLIC_* because the site is static
# and just exists for marketing + support. Anything sensitive belongs in
# the backend, not here.

# ── Site identity ────────────────────────────────────────────
NEXT_PUBLIC_SITE_NAME=ShareCab
# Canonical URL — used in <meta>, sitemap, and absolute Open Graph links.
NEXT_PUBLIC_SITE_URL=https://sharecab.example
# Public backend API root for future interactive website features.
NEXT_PUBLIC_API_BASE_URL=https://sharecab-backend-bbxdisvagq-el.a.run.app

# ── App download links (primary CTAs) ────────────────────────
# Where the "Get the app" buttons point. Leave blank to render the
# button as a disabled "Coming soon" state.
NEXT_PUBLIC_APP_STORE_URL=
NEXT_PUBLIC_PLAY_STORE_URL=

# ── Support ──────────────────────────────────────────────────
NEXT_PUBLIC_SUPPORT_EMAIL=anandrahul044@gmail.com
NEXT_PUBLIC_DRIVER_SUPPORT_EMAIL=anandrahul044@gmail.com
NEXT_PUBLIC_PARTNERSHIPS_EMAIL=anandrahul044@gmail.com

# Where the /contact form POSTs (Formspree, Resend, a Lambda, etc.).
# Leave blank to keep the form as a no-op placeholder.
NEXT_PUBLIC_CONTACT_FORM_ENDPOINT=

# ── Analytics (optional) ─────────────────────────────────────
# Set one if you want tracking. Leave blank to ship no scripts.
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
