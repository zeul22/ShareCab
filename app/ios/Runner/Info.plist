	<!-- ==================== Privacy / permissions usage strings ====================
	     Each must accurately describe WHY we need the permission AND
	     what we do with the data. App Store review reads these; vague
	     strings ("App needs location") are a guaranteed rejection. -->

	<!-- Foreground location — used for the map, pickup detection, and
	     the matching engine's pickup-radius check. No background
	     tracking; no historical-trail logging. -->
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>ShareCab uses your location to set your pickup point, find nearby co-riders, and show the live route to your destination. We only access location while the app is open.</string>

	<!-- Apple still requires this string even if you don't intend to
	     run a background-location update — `geolocator` ships the
	     capability and review-time linting checks for the string. -->
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>ShareCab uses your location to set your pickup point and show the live route to your destination. We never track your location while the app is closed.</string>

	<!-- ==================== Outbound URL schemes ====================
	     iOS 9+ requires apps to declare URL schemes they call via
	     `canOpenURL` / `openURL`. We open the OS dialer when calling
	     ShareCab support, the mail composer for support emails, and
	     google maps for directions previews. SMS isn't used today but
	     left here to cover the in-app "Share your trip" feature when
	     wired. -->
	<key>LSApplicationQueriesSchemes</key>
	<array>
		<string>tel</string>
		<string>mailto</string>
		<string>sms</string>
		<string>comgooglemaps</string>
	</array>

	<!-- ==================== Network ====================
	     Tightened App Transport Security. Allowing local networking
	     covers `flutter run` against a host backend (10.0.2.2 / .local).
	     NO arbitrary cleartext loads — anything else must be HTTPS. -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsLocalNetworking</key>
		<true/>
		<key>NSAllowsArbitraryLoads</key>
		<false/>
	</dict>

	<!-- ==================== Submission checklist ====================
	     Before any TestFlight build / App Store submission:
	       1. Replace bundle id `com.example.sharecab` with your real id
	          in Xcode (Runner target → General → Bundle Identifier).
	          Match the value in your Apple Developer team's App ID.
	       2. Replace the AdMob app id above with your real
	          `ca-app-pub-XXXX~XXXX` (Test ads still work post-swap
	          via the rewarded ad unit id in api_config.dart).
	       3. Replace GMSApiKey with a Cloud-Console-restricted iOS key.
	       4. Set up real privacy policy URL + support URL in App Store
	          Connect → App Privacy section.
	       5. Fill the Privacy Nutrition Label truthfully — location,
	          identifiers (phone), purchases (Razorpay unlock), usage
	          data (analytics), and "data linked to user" boxes apply.
	       6. Add 6.7" + 5.5" screenshots and an App Preview video.
	       7. Confirm the SKAdNetwork list above is current — refresh
	          from developers.google.com/admob/ios/ios14 each release.
	-->
