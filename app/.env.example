# Pass these via --dart-define when building / running:
#
#   flutter run \
#     --dart-define=API_BASE_URL=http://10.0.2.2:4000 \
#     --dart-define=GOOGLE_MAPS_KEY=AIzaSy...your-key \
#     --dart-define=MSG91_WIDGET_ID=... \
#     --dart-define=MSG91_WIDGET_AUTH_TOKEN=...
#
# Defaults are set in lib/utils/api_config.dart for local development. If
# MSG91 widget credentials are configured on the backend instead, the app
# fetches them from /api/auth/otp/msg91/config at startup.
#
# GOOGLE_MAPS_KEY is used by the Places autocomplete widget. The native map
# rendering on Android/iOS uses keys configured in the platform projects
# (see app/README.md).

API_BASE_URL=http://10.0.2.2:4000
GOOGLE_MAPS_KEY=
MSG91_WIDGET_ID=
MSG91_WIDGET_AUTH_TOKEN=
