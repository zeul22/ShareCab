# Pass these via --dart-define when building / running:
#
#   flutter run \
#     --dart-define=API_BASE_URL=http://10.0.2.2:4000 \
#     --dart-define=GOOGLE_MAPS_KEY=AIzaSy...your-key
#
# Defaults are set in lib/utils/api_config.dart for local development.
#
# GOOGLE_MAPS_KEY is used by the Places autocomplete widget. The native map
# rendering on Android/iOS uses keys configured in the platform projects
# (see app/README.md).

API_BASE_URL=http://10.0.2.2:4000
GOOGLE_MAPS_KEY=
