<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- ==================== Permissions ====================
         Every permission must be justified in the Play Console's Data
         Safety form. If you stop using one, remove it here too —
         Google flags unused dangerous permissions on review.
    -->

    <!-- Network. Required by every plugin that talks to a server. -->
    <uses-permission android:name="android.permission.INTERNET"/>
    <!-- AdMob + offline detection. Lets google_mobile_ads know whether
         to attempt an ad load and helps Razorpay surface "no network"
         errors gracefully. -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE"/>

    <!-- Foreground location. `ACCESS_COARSE_LOCATION` is the floor on
         Android 12+; `ACCESS_FINE_LOCATION` gets us GPS-accurate
         coordinates for the pickup picker. We do NOT request the
         BACKGROUND_LOCATION permission — we don't track when the app
         is closed. -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION"/>
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION"/>

    <!-- Android 13+ requires an explicit permission to post any
         notification. Without it, `flutter_local_notifications` silently
         no-ops on Tiramisu (API 33) and above. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>

    <!-- ==================== Feature declarations ====================
         Marking location features as NOT required keeps the app
         installable on tablets / devices without a GPS chip. (Without
         this, Play Store filters out a chunk of compatible devices.)
    -->
    <uses-feature
        android:name="android.hardware.location"
        android:required="false"/>
    <uses-feature
        android:name="android.hardware.location.gps"
        android:required="false"/>
    <uses-feature
        android:name="android.hardware.location.network"
        android:required="false"/>

    <application
        android:label="ShareCab"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher"
        android:networkSecurityConfig="@xml/network_security_config"
        android:usesCleartextTraffic="false">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <!-- ==================== API keys ==================== -->

        <!-- Google Maps Platform API key — required by google_maps_flutter
             on Android. Replace with a Cloud-Console-restricted Android
             key (package id + SHA-1 fingerprint) before submission. -->
        <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="***REMOVED_GOOGLE_MAPS_KEY***"/>

        <!-- AdMob — required by google_mobile_ads to initialise. The
             value below is AdMob's OFFICIAL test app id (documented at
             developers.google.com/admob/android/test-ads). Replace
             with your real `ca-app-pub-*` id before going to prod.
             Test app id is harmless in production but always serves
             test ads — never monetises until swapped. -->
        <meta-data
            android:name="com.google.android.gms.ads.APPLICATION_ID"
            android:value="ca-app-pub-3940256099942544~3347511713"/>

        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
    </application>

    <!-- ==================== Package visibility (Android 11+) ====================
         Android 11 ringfences which other apps yours can see / open.
         These `queries` blocks explicitly whitelist the intents we
         dispatch from inside the app:
           - PROCESS_TEXT: Flutter engine's text-actions plugin.
           - tel:        Calling support hotline from the help screen.
           - mailto:     Email support / contact link.
           - smsto:      "Share your trip" SMS (reserved for future use).
           - https:      Opening the privacy policy / terms web pages.
         Without these, intent dispatch silently fails on Android 11+.
    -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
        <intent>
            <action android:name="android.intent.action.DIAL"/>
            <data android:scheme="tel"/>
        </intent>
        <intent>
            <action android:name="android.intent.action.SENDTO"/>
            <data android:scheme="mailto"/>
        </intent>
        <intent>
            <action android:name="android.intent.action.SENDTO"/>
            <data android:scheme="smsto"/>
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW"/>
            <data android:scheme="https"/>
        </intent>
    </queries>
</manifest>
