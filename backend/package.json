{
  "name": "sharecab-backend",
  "version": "0.1.0",
  "private": true,
  "description": "ShareCab backend — REST API, matching engine, and realtime location for the cab-sharing platform.",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "dev:e2e": "node src/devServer.js",
    "db:up": "cd .. && docker compose up -d mongo",
    "db:down": "cd .. && docker compose down",
    "db:logs": "cd .. && docker compose logs -f mongo",
    "db:reset": "cd .. && docker compose down -v && docker compose up -d mongo",
    "lint": "eslint src/",
    "test": "jest"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.5.0",
    "morgan": "^1.10.0",
    "socket.io": "^4.7.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "eslint": "^9.7.0",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^9.4.0",
    "nodemon": "^3.1.4"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 60000,
    "testMatch": [
      "<rootDir>/tests/**/*.test.js"
    ]
  },
  "engines": {
    "node": ">=18"
  }
}
