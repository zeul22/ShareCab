# Server
PORT=4000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/sharecab

# Auth
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d

# MSG91 OTP
# Server-side authkey used only to validate the Flutter widget access token.
# Never expose this in the Flutter app.
MSG91_AUTH_KEY=
# Optional public widget credentials. The backend serves these to the app at
# /api/auth/otp/msg91/config when the app is not built with dart-defines.
# These are client-side SDK credentials, not the server authkey.
MSG91_WIDGET_ID=
MSG91_WIDGET_AUTH_TOKEN=
# Local-only escape hatch. When true, /auth/otp/request returns DEV_OTP and
# /auth/otp/verify accepts it without calling MSG91. Never enable in prod.
MSG91_DEV_FALLBACK=false
DEV_OTP=123456

# Driver dispatch (Uber-style accept/reject offer flow)
# How long a driver has to accept/reject an offered trip before we auto-
# reject and re-dispatch to the next-nearest driver. 15s mirrors Uber/Ola.
DISPATCH_OFFER_TIMEOUT_MS=15000
# Max distance (metres) the matching engine looks when finding a driver.
DISPATCH_RADIUS_METERS=5000

# Matching engine tunables
# Maximum distance between two destinations to consider a shared ride (in km)
MATCH_DESTINATION_RADIUS_KM=4
# Maximum distance between two pickup points to consider sharing (in km)
MATCH_PICKUP_RADIUS_KM=2
# Maximum detour a driver should accept while picking up a co-rider (in km)
MATCH_MAX_DETOUR_KM=2
# Maximum number of riders that can share a single cab
MATCH_MAX_RIDERS_PER_CAB=3

# Fare model (INR by default — adjust per market)
FARE_BASE=30
FARE_PER_KM=12
FARE_PER_MIN=1
FARE_SHARE_DISCOUNT=0.30

# Razorpay
# API key id + secret from dashboard.razorpay.com → Account & Settings → API Keys.
# Test mode keys start with rzp_test_ — safe for development, no real money.
# Production lives in Secret Manager (see docs/deployment.md), not in this file.
# When both are empty, razorpayClient.js falls back to stub mode (synthetic
# orderId, signature check no-ops). Useful for local dev without a Razorpay
# account; MUST be configured in production.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Separate from API secret. Used by the webhook handler to verify
# X-Razorpay-Signature on inbound events. Generate with:
#   openssl rand -hex 32
# Then paste the same value into the Razorpay dashboard webhook config.
RAZORPAY_WEBHOOK_SECRET=

# Notifications (placeholder — wire to FCM / APNS / SMS in production)
FCM_SERVER_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# CORS
CORS_ORIGIN=http://localhost:3000
