# Server
PORT=4000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/sharecab

# Auth
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d

# Matching engine tunables
# Maximum distance between two destinations to consider a shared ride (in km)
MATCH_DESTINATION_RADIUS_KM=4
# Maximum distance between two pickup points to consider sharing (in km)
MATCH_PICKUP_RADIUS_KM=2
# Maximum detour a driver should accept while picking up a co-rider (in km)
MATCH_MAX_DETOUR_KM=2
# Maximum number of riders that can share a single cab
MATCH_MAX_RIDERS_PER_CAB=3

# Fare model (INR by default — adjust per market)
FARE_BASE=30
FARE_PER_KM=12
FARE_PER_MIN=1
FARE_SHARE_DISCOUNT=0.30

# Notifications (placeholder — wire to FCM / APNS / SMS in production)
FCM_SERVER_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# CORS
CORS_ORIGIN=http://localhost:3000
