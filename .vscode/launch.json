{
  // Flutter debug configurations for the ShareCab monorepo.
  // The Flutter app lives in /app — cwd anchors the launcher there so
  // `flutter run` finds pubspec.yaml correctly.
  //
  // The Google Maps key below is a *demo* key. Before making this repo public:
  //   1. Restrict it in Google Cloud Console (Android pkg + SHA-1, iOS bundle ID).
  //   2. Rotate it once the demo phase is over.
  //
  // Two-emulator workflow:
  //   - Boot both an iOS Simulator and an Android emulator before launching.
  //   - Pick "ShareCab App (iOS + Android)" to launch on both at once.
  //   - Each debug session has its own Debug Console; hot-reload is per-session.
  //
  // Note on API base URLs:
  //   - Android emulator → host machine: 10.0.2.2 (special alias)
  //   - iOS simulator   → host machine: localhost
  "version": "0.2.0",
  "configurations": [
    {
      "name": "ShareCab App (iOS Simulator)",
      "type": "dart",
      "request": "launch",
      "cwd": "${workspaceFolder}/app",
      "program": "lib/main.dart",
      "flutterMode": "debug",
      "deviceId": "iphone",
      "toolArgs": [
        "--dart-define=API_BASE_URL=http://localhost:4000",
        "--dart-define=GOOGLE_MAPS_KEY=***REMOVED_GOOGLE_MAPS_KEY***"
      ]
    },
    {
      "name": "ShareCab App (Android Emulator)",
      "type": "dart",
      "request": "launch",
      "cwd": "${workspaceFolder}/app",
      "program": "lib/main.dart",
      "flutterMode": "debug",
      "deviceId": "android",
      "toolArgs": [
        "--dart-define=API_BASE_URL=http://10.0.2.2:4000",
        "--dart-define=GOOGLE_MAPS_KEY=***REMOVED_GOOGLE_MAPS_KEY***"
      ]
    },
    {
      "name": "ShareCab App (debug, pick device)",
      "type": "dart",
      "request": "launch",
      "cwd": "${workspaceFolder}/app",
      "program": "lib/main.dart",
      "flutterMode": "debug",
      "toolArgs": [
        "--dart-define=API_BASE_URL=http://10.0.2.2:4000",
        "--dart-define=GOOGLE_MAPS_KEY=***REMOVED_GOOGLE_MAPS_KEY***"
      ]
    },
    {
      "name": "ShareCab App (profile)",
      "type": "dart",
      "request": "launch",
      "cwd": "${workspaceFolder}/app",
      "program": "lib/main.dart",
      "flutterMode": "profile",
      "toolArgs": [
        "--dart-define=API_BASE_URL=http://10.0.2.2:4000",
        "--dart-define=GOOGLE_MAPS_KEY=***REMOVED_GOOGLE_MAPS_KEY***"
      ]
    },
    {
      "name": "ShareCab App (release)",
      "type": "dart",
      "request": "launch",
      "cwd": "${workspaceFolder}/app",
      "program": "lib/main.dart",
      "flutterMode": "release",
      "toolArgs": [
        "--dart-define=API_BASE_URL=http://10.0.2.2:4000",
        "--dart-define=GOOGLE_MAPS_KEY=***REMOVED_GOOGLE_MAPS_KEY***"
      ]
    },
    {
      "name": "ShareCab App (debug, custom Maps key)",
      "type": "dart",
      "request": "launch",
      "cwd": "${workspaceFolder}/app",
      "program": "lib/main.dart",
      "flutterMode": "debug",
      "toolArgs": [
        "--dart-define=API_BASE_URL=http://10.0.2.2:4000",
        "--dart-define=GOOGLE_MAPS_KEY=${input:googleMapsKey}"
      ]
    },
    {
      "name": "ShareCab Driver (iOS Simulator)",
      "type": "dart",
      "request": "launch",
      "cwd": "${workspaceFolder}/driver",
      "program": "lib/main.dart",
      "flutterMode": "debug",
      "deviceId": "iphone",
      "toolArgs": [
        "--dart-define=API_BASE_URL=http://localhost:4000"
      ]
    },
    {
      "name": "ShareCab Driver (Android Emulator)",
      "type": "dart",
      "request": "launch",
      "cwd": "${workspaceFolder}/driver",
      "program": "lib/main.dart",
      "flutterMode": "debug",
      "deviceId": "android",
      "toolArgs": [
        "--dart-define=API_BASE_URL=http://10.0.2.2:4000"
      ]
    },
    {
      "name": "ShareCab Driver (debug, pick device)",
      "type": "dart",
      "request": "launch",
      "cwd": "${workspaceFolder}/driver",
      "program": "lib/main.dart",
      "flutterMode": "debug",
      "toolArgs": [
        "--dart-define=API_BASE_URL=http://10.0.2.2:4000"
      ]
    },
    {
      "name": "ShareCab Driver (profile)",
      "type": "dart",
      "request": "launch",
      "cwd": "${workspaceFolder}/driver",
      "program": "lib/main.dart",
      "flutterMode": "profile",
      "toolArgs": [
        "--dart-define=API_BASE_URL=http://10.0.2.2:4000"
      ]
    },
    {
      "name": "ShareCab Driver (release)",
      "type": "dart",
      "request": "launch",
      "cwd": "${workspaceFolder}/driver",
      "program": "lib/main.dart",
      "flutterMode": "release",
      "toolArgs": [
        "--dart-define=API_BASE_URL=http://10.0.2.2:4000"
      ]
    },

    // -------------------------------------------------------------------
    // Multi-device flow testing — pinned to specific named simulators so
    // you can launch two riders + one driver from VS Code and get full
    // debugger / breakpoint support in three separate debug sessions.
    //
    // Each `deviceId` is matched as a substring against `flutter devices`
    // output. The simulators must exist (one-time create — see Makefile
    // section "Multi-device flow testing"). VS Code launches each session
    // in its own Debug Console; ⌘+R / Cmd+\ hot-reload still works per
    // session, set breakpoints in lib/** as normal.
    // -------------------------------------------------------------------
    {
      "name": "Rider A · iPhone 16e",
      "type": "dart",
      "request": "launch",
      "cwd": "${workspaceFolder}/app",
      "program": "lib/main.dart",
      "flutterMode": "debug",
      "deviceId": "iPhone 16e (Rider A)",
      "toolArgs": [
        "--dart-define=API_BASE_URL=http://localhost:4000",
        "--dart-define=GOOGLE_MAPS_KEY=***REMOVED_GOOGLE_MAPS_KEY***"
      ]
    },
    {
      "name": "Rider B · iPhone 16e",
      "type": "dart",
      "request": "launch",
      "cwd": "${workspaceFolder}/app",
      "program": "lib/main.dart",
      "flutterMode": "debug",
      "deviceId": "iPhone 16e (Rider B)",
      "toolArgs": [
        "--dart-define=API_BASE_URL=http://localhost:4000",
        "--dart-define=GOOGLE_MAPS_KEY=***REMOVED_GOOGLE_MAPS_KEY***"
      ]
    },
    {
      "name": "Driver D1 · iPhone 16e",
      "type": "dart",
      "request": "launch",
      "cwd": "${workspaceFolder}/driver",
      "program": "lib/main.dart",
      "flutterMode": "debug",
      "deviceId": "iPhone 16e (Driver)",
      "toolArgs": [
        "--dart-define=API_BASE_URL=http://localhost:4000"
      ]
    }
  ],
  "compounds": [
    {
      "name": "ShareCab App (iOS + Android)",
      "configurations": [
        "ShareCab App (iOS Simulator)",
        "ShareCab App (Android Emulator)"
      ],
      "stopAll": true
    },
    {
      "name": "ShareCab Rider + Driver (iOS Simulators)",
      "configurations": [
        "ShareCab App (iOS Simulator)",
        "ShareCab Driver (iOS Simulator)"
      ],
      "stopAll": true
    },
    {
      "name": "ShareCab Rider + Driver (Android Emulators)",
      "configurations": [
        "ShareCab App (Android Emulator)",
        "ShareCab Driver (Android Emulator)"
      ],
      "stopAll": true
    },
    {
      // Launch all three iPhone 16e sims at once with full debugger
      // attach. Make sure the three named simulators exist + are booted
      // (`make r1` etc bootstraps them; this compound just attaches the
      // debugger instead of running flutter from the terminal).
      "name": "ShareCab 2 Riders + 1 Driver (iOS Simulators)",
      "configurations": [
        "Rider A · iPhone 16e",
        "Rider B · iPhone 16e",
        "Driver D1 · iPhone 16e"
      ],
      "stopAll": true
    }
  ],
  "inputs": [
    {
      "id": "googleMapsKey",
      "type": "promptString",
      "description": "Google Maps Platform API key — overrides the bundled demo key.",
      "default": ""
    }
  ]
}
