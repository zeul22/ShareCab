# Pass these via --dart-define when building / running:
#
#   flutter run \
#     --dart-define=API_BASE_URL=http://10.0.2.2:4000 \
#     --dart-define=GOOGLE_MAPS_KEY=AIzaSy...your-restricted-key \
#     --dart-define=MSG91_WIDGET_ID=... \
#     --dart-define=MSG91_WIDGET_AUTH_TOKEN=...
#
# In the public-source repo, the driver app is for UI review and local demo
# work. Production driver dispatch is gated on the backend by
# ENABLE_PRODUCTION_DRIVER_OPS=true and private provider credentials.

API_BASE_URL=http://10.0.2.2:4000
GOOGLE_MAPS_KEY=
MSG91_WIDGET_ID=
MSG91_WIDGET_AUTH_TOKEN=
